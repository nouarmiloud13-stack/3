# ── HuggingFace (téléchargement modèle Gemma4) ───────────────
HF_TOKEN=hf_glTuXALPcepaMoXhYmsVnFzdYVyScYSpg

# ── ngrok — Tunnel HTTPS vers l'API REST ─────────────────────
NGROK_AUTHTOKEN=3EeFHB5PrLVStD4be1cTcprtnMx_6YWZEq99HtyzDSSRrXMr
NGROK_DOMAIN=theology-custody-rocky.ngrok-free.dev
NGROK_URL=https://theology-custody-rocky.ngrok-free.dev

# ── Mode LOCAL — URL sans ngrok ───────────────────────────────
# Utilisé par : make start-local
# Aucune configuration DNS nécessaire (.localhost résolu par le navigateur)
LOCAL_URL=http://localhost:5000

# ── Arduino — PORT SÉRIE RÉEL ─────────────────────────────────
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUD=9600

# ── Gemma4 — IA locale (llama.cpp) ───────────────────────────
GEMMA4_VARIANT=e2b
GEMMA4_QUANT=Q4_K_M
GEMMA4_DEST=docker/models/gemma4
GEMMA4_MODEL_FILE=google_gemma-4-E2B-it-Q4_K_M.gguf
GEMMA4_MMPROJ_FILE=mmproj-google_gemma-4-E2B-it-bf16.gguf
GEMMA4_HOST=gemma4
GEMMA4_SERVER_PORT=8080
GEMMA4_CTX=4096
GEMMA4_THREADS=4
GEMMA4_GPU_LAYERS=0
GEMMA4_TIMEOUT=45
GEMMA4_TEMPERATURE=0.15
GEMMA4_SYSTEM_PROMPT="Tu es un système d'IA embarqué expert en surveillance de réservoirs GNL (Gaz Naturel Liquéfié). Analyse les données capteurs et fournis des décisions de sécurité. Réponds en JSON valide uniquement."

# ── Sélection du fournisseur IA ───────────────────────────────
GNL_AI_PROVIDER=gemma4

# ── Smart AI — Paramètres d'analyse ──────────────────────────
GNL_AI_INTERVAL=30
GNL_AI_RISK_TRIGGER=60
GNL_AI_MAX_TOKENS=512

# ── Watchdog — Sécurité système ───────────────────────────────
WATCHDOG_TIMEOUT_S=5000
WATCHDOG_MAX_ERRORS=10
WATCHDOG_TICK_S=2.0
WATCHDOG_SENSORS_DEAD_MAX=5
ESD_ACK_TIMEOUT_S=10
WATCHDOG_OS_SHUTDOWN=false

# ── Seuils IA (AnomalyEngine + Watchdog) ─────────────────────
GAS_WARN=250
GAS_DANGER=450
LEVEL_HIGH=95
LEVEL_LOW=10
CONFIRM_GAS=3

# ── MongoDB — Historique GNL ──────────────────────────────────
MONGO_USER=nouar
MONGO_PASS=hamel
MONGO_DB=gnl_history
MONGO_TTL_DAYS=30
MONGO_URI=mongodb://nouar:hamel@mongodb:27017/
MONGO_EXPRESS_USER=nouar
MONGO_EXPRESS_PASS=hamel

# ── MQTT Mosquitto ────────────────────────────────────────────
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_TLS=false
MQTT_USER_PUBLISHER=nouar
MQTT_PASS_PUBLISHER=hamel
MQTT_USER_DASHBOARD=nouar
MQTT_PASS_DASHBOARD=hamel
MQTT_USER_ADMIN=nouar
MQTT_PASS_ADMIN=hamel

# ── API REST Flask / JWT ──────────────────────────────────────
GNL_JWT_SECRET=hamel
API_HOST=0.0.0.0
API_PORT=5000

# ── AES-256-GCM — Chiffrement mot de passe Admin ─────────────
# Clé 32 bytes encodée en base64 (256 bits = AES-256)
# Générer une nouvelle clé : python3 -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
AES_SECRET_KEY=bXlfc2VjcmV0X2tleV8zMl9ieXRlc19mb3JfYWVzMjU2IQ==

# Sel pour PBKDF2 (optionnel, valeur par défaut si absent)
AES_SALT=gnl_usto_mb_2025
